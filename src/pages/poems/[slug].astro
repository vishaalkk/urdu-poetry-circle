---
import Layout from '../../layouts/Layout.astro';
import poemsData from '../../content/poems.json';

export function getStaticPaths() {
  return poemsData.map(p => ({
    params: { slug: p.slug },
    props: { poem: p }
  }));
}

const { poem } = Astro.props;

// Aggregate all performances from all readings
const allPerformances = poem.readings.flatMap(r => {
  if (!r.music) return [];
  return r.music.split('- ').filter(Boolean).map(m => {
    const parts = m.split(': ');
    const name = parts[0];
    const url = parts[1] || "";
    const embedUrl = url.includes('watch?v=') ? url.replace('watch?v=', 'embed/').split('&')[0] : url;
    return { name, url: embedUrl, date: r.date };
  });
});

// Remove duplicates based on URL
const uniquePerformances = Array.from(new Map(allPerformances.map(p => [p.url, p])).values());

// Aggregate all PDFs
const allPDFs = poem.readings.flatMap(r => {
  if (!r.pdfs) return [];
  // Parse Airtable format: "filename (url)"
  const matches = r.pdfs.match(/\((https?:\/\/[^\)]+)\)/g);
  if (!matches) return [];
  return matches.map(m => m.slice(1, -1));
});
const uniquePDFs = [...new Set(allPDFs)];
---

<Layout title={`${poem.title} | ${poem.poet}`}>
	<article class="max-w-3xl mx-auto py-12">
		<header class="text-center mb-24">
			<h1 class="text-4xl md:text-5xl italic leading-tight mb-4">{poem.title}</h1>
			<div class="font-sans text-[10px] uppercase tracking-[0.4em] text-journal-faded mb-8">{poem.poet}</div>
			<div class="h-px w-16 bg-black/10 mx-auto"></div>
		</header>

		<!-- Timeline / History of Readings -->
		<section class="mb-24">
			<div class="font-sans text-[10px] uppercase tracking-[0.3em] text-center mb-8 text-journal-faded">Reading History</div>
			<div class="flex flex-wrap justify-center gap-4">
				{poem.readings.map(r => (
					<div class="px-6 py-2 bg-journal-tan text-journal-green border border-journal-green/10 rounded-full font-serif italic text-sm font-bold shadow-sm transition-transform hover:scale-105">
						{new Date(r.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
					</div>
				))}
			</div>
		</section>

		{(poem.fran || poem.rekhta) && (
			<section class="mt-24 border-t border-black/5 pt-12 text-center">
				<h2 class="font-sans text-[10px] uppercase tracking-[0.3em] mb-8 text-journal-faded">Text & Resources</h2>
				<div class="flex justify-center gap-12 font-serif italic text-lg mb-12">
					{poem.fran && <a href={poem.fran} target="_blank" class="hover:text-journal-accent transition-colors border-b border-black/10 hover:border-journal-accent/30">Desertful of Roses</a>}
					{poem.rekhta && <a href={poem.rekhta} target="_blank" class="hover:text-journal-accent transition-colors border-b border-black/10 hover:border-journal-accent/30">Rekhta</a>}
				</div>

				{poem.fran && (
					<div class="mt-12 bg-white p-4 shadow-sm border border-black/5">
						<div class="font-sans text-[9px] uppercase tracking-widest mb-4 text-journal-faded text-left">Reading Room: Desertful of Roses</div>
						<div class="aspect-[3/4] md:aspect-square w-full overflow-hidden rounded-sm border border-black/5">
							<iframe 
								src={poem.fran} 
								class="w-full h-full grayscale-[0.5] hover:grayscale-0 transition-all duration-700"
								title="Poem Text"
								loading="lazy"
							/>
						</div>
					</div>
				)}

				{uniquePDFs.map((pdf, index) => (
					<div class="mt-12 bg-white p-4 shadow-sm border border-black/5">
						<div class="font-sans text-[9px] uppercase tracking-widest mb-4 text-journal-faded text-left">Document Archive: Scanned Version {uniquePDFs.length > 1 ? index + 1 : ''}</div>
						<div class="aspect-[3/4] md:aspect-square w-full overflow-hidden rounded-sm border border-black/5">
							<iframe 
								src={pdf} 
								class="w-full h-full grayscale-[0.5] hover:grayscale-0 transition-all duration-700"
								title="Poem PDF"
								loading="lazy"
							/>
						</div>
						<a href={pdf} target="_blank" class="mt-4 inline-block font-sans text-[9px] uppercase tracking-widest text-journal-faded hover:text-journal-accent">Open in Fullscreen &rarr;</a>
					</div>
				))}
			</section>
		)}

		{uniquePerformances.length > 0 && (
			<section class="mt-32 border-t border-black/5 pt-24">
				<h2 class="font-sans text-xs uppercase tracking-[0.3em] text-center mb-16 text-journal-faded">Performances</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
					{uniquePerformances.map(p => (
						<div class="group">
							<div class="aspect-video bg-neutral-100 mb-6 overflow-hidden shadow-sm relative">
								<iframe 
									class="w-full h-full grayscale group-hover:grayscale-0 transition-all duration-700"
									src={p.url} 
									title={p.name}
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
									allowfullscreen
								/>
							</div>
							<div class="text-center">
								<div class="font-sans text-[10px] uppercase tracking-widest text-journal-text mb-2">
									{p.name}
								</div>
								<a 
									href={p.url.replace('embed/', 'watch?v=')} 
									target="_blank" 
									class="inline-block font-serif italic text-xs text-journal-faded hover:text-journal-accent border-b border-black/5 hover:border-journal-accent/30 transition-all"
								>
									Watch on YouTube &rarr;
								</a>
							</div>
						</div>
					))}
				</div>
			</section>
		)}
	</article>
</Layout>
